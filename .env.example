# ── Supabase (required) ──────────────────────────────────────────────────────
# 1) API URL + publishable key: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"

# 2) Database URI (REQUIRED for Prisma — NOT the https:// API URL above)
#
# Local migrate/seed — use Direct connection (port 5432):
#   Supabase → Connect → Direct connection → URI
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
#
# Vercel (serverless) — prefer Session pooler (port 5432 on *.pooler.supabase.com):
#   Supabase → Connect → Session pooler → URI
#   Or Transaction pooler :6543 (also works with our pg adapter)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Optional: service role (server-only, never expose to browser)
# SUPABASE_SERVICE_ROLE_KEY="..."

# ── Auth.js (admin CRM) — generate yourself, not from Supabase ───────────────
# openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Production: your Vercel URL, e.g. https://vmk-tennis-academy.vercel.app
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

ADMIN_PASSWORD="ChangeMeImmediately1!"

EMAIL_FROM="VMK Tennis Academy <noreply@vmkta.com>"
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=

UPLOAD_PROVIDER=local
