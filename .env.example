# ── Supabase (required) ──────────────────────────────────────────────────────
# 1) API URL + publishable key: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"

# 2) Database URI (REQUIRED for Prisma — this is NOT the https:// URL above)
#    Supabase → Connect → Connection string → URI → Transaction (port 6543)
#    Replace YOUR_PASSWORD with the database password
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require"

# Optional: service role (server-only, never expose to browser)
# SUPABASE_SERVICE_ROLE_KEY="..."

# ── Auth.js (admin CRM) — generate yourself, not from Supabase ───────────────
# openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"

ADMIN_PASSWORD="ChangeMeImmediately1!"

EMAIL_FROM="VMK Tennis Academy <noreply@vmkta.com>"
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=

UPLOAD_PROVIDER=local
