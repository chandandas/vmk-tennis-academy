# ── Supabase (required) — same project for local + Vercel ─────────────────────
# 1) API URL + publishable key: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"

# 2) Database URI (REQUIRED for Prisma — NOT the https:// API URL)
# Use Session pooler for BOTH localhost and Vercel (direct db.* is IPv6-only).
# Supabase → Connect → Session pooler → URI
# Username is postgres.PROJECT_REF ; host like aws-1-REGION.pooler.supabase.com:5432
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"

# Optional: direct connection for rare migrate/seed issues
# DATABASE_URL_DIRECT="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Optional: service role (server-only, never expose to browser)
# SUPABASE_SERVICE_ROLE_KEY="..."

# ── Auth.js (admin CRM) — same AUTH_SECRET on local + Vercel ──────────────────
# openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"

ADMIN_PASSWORD="ChangeMeImmediately1!"

EMAIL_FROM="VMK Tennis Academy <noreply@vmkta.com>"
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=

UPLOAD_PROVIDER=local
